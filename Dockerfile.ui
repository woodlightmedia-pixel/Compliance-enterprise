# =====================================================================
# ENTERPRISE FRONTEND: Streamlit User Dashboard
# =====================================================================
FROM python:3.11-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
ENV HOME=/app

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# Layer caching for Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

# Copy only the UI code
COPY src/ui/ ./src/ui/

# Enforce Non-Root Security
RUN useradd -u 8888 appuser && chown -R appuser:appuser /app
USER appuser

# Expose dynamic port for Google Cloud Run
ENV PORT=8080
EXPOSE 8080

CMD streamlit run src/ui/app.py --server.port=${PORT:-8080}
